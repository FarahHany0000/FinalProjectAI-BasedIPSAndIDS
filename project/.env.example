# === Server Configuration ===
FLASK_ENV=development
SECRET_KEY=change-me-to-random-64-chars
JWT_SECRET_KEY=change-me-to-random-64-chars

# === Database ===
DATABASE_URL=sqlite:///ids.db

# === Agent Authentication ===
AGENT_KEY=change-me-to-random-32-chars

# === Server Address (for agents to connect to) ===
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# === AI Models ===
AI_MODELS_PATH=./ai_models

# === Frontend ===
FRONTEND_URL=http://localhost:5173

# === Network Sensor (Solution 2: Laptop5 as Gateway) ===
# The network interface name for the hosted hotspot
# On Windows: "Local Area Connection* 12" (check with ipconfig)
SENSOR_INTERFACE=auto
SENSOR_CAPTURE_TIMEOUT=5
SENSOR_FLOW_TIMEOUT=120
